# Copia este archivo como .env y rellena los valores para desarrollo local.
# En Railway estas variables se definen en el panel del proyecto.

# Clave para firmar sesiones/cookies. En producción usa una cadena larga y aleatoria.
SECRET_KEY=cambia-esto-por-una-cadena-aleatoria

# Base de datos.
# - En LOCAL: deja DATABASE_URL vacío -> se usa SQLite (galeria_dev.db) automáticamente.
# - En RAILWAY: se inyecta sola al añadir el servicio Postgres.
DATABASE_URL=

# Cloudinary (fase 4 - subida de imágenes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Administrador inicial del panel (fase 2 - autenticación)
ADMIN_EMAIL=
ADMIN_PASSWORD=
